PORT=5000

# PostgreSQL (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geofest_db
DB_USER=postgres
DB_PASSWORD=your_password

# PostgreSQL (Vercel/Neon/Supabase — overrides individual vars above if set)
DATABASE_URL=

# ─── UPI Payment ──────────────────────────────────────────────────────────────
UPI_ID=geofest@upi
UPI_NAME=GeoFest 2026

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) — for approval confirmation emails ─────────────────────────
# Gmail: enable 2FA and generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="GeoFest 2026" <your@gmail.com>

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=6tfcvgY%2026GeoFest

# ─── Frontend URL (used in redirects) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
