# PostgreSQL (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=geofest_db
DB_USER=postgres
DB_PASSWORD=your_password

# PostgreSQL (Vercel/Neon/Supabase — overrides individual vars above if set)
